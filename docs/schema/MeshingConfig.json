{
  "$defs": {
    "ConditionTarget": {
      "description": "Whether a condition attaches to a 3D body or a 2D boundary.\n\nA fixed vocabulary, so it is an enum rather than a bare ``\"body\"`` /\n``\"boundary\"`` string (doc 06, \"no magic words\"): autocomplete shows the\nlegal values and a typo is a static error.",
      "enum": [
        "body",
        "boundary"
      ],
      "title": "ConditionTarget",
      "type": "string"
    },
    "Convection": {
      "description": "Convective (Newton-cooling) boundary condition (thermal, boundary target).\n\nCarries both the heat-transfer coefficient *and* the external temperature it\nexchanges with \u2014 together they fully specify the boundary, which a lone\ncoefficient could not.",
      "properties": {
        "physics": {
          "$ref": "#/$defs/Physics",
          "default": "thermal"
        },
        "target": {
          "$ref": "#/$defs/ConditionTarget",
          "default": "boundary"
        },
        "kind": {
          "const": "convection",
          "default": "convection",
          "title": "Kind",
          "type": "string"
        },
        "coefficient": {
          "description": "Convective heat-transfer coefficient (W/m^2/K).",
          "title": "Coefficient",
          "type": "string",
          "x-unit-dimensionality": "[power]/[length]**2/[temperature]"
        },
        "ext_temperature": {
          "description": "External (ambient) temperature (K) the boundary exchanges with.",
          "title": "Ext Temperature",
          "type": "string",
          "x-unit-dimensionality": "[temperature]"
        }
      },
      "required": [
        "coefficient",
        "ext_temperature"
      ],
      "title": "Convection",
      "type": "object"
    },
    "ElectricalProperties": {
      "properties": {
        "conductivity": {
          "anyOf": [
            {
              "description": "pint quantity with dimensionality [current]**2*[time]**3/[mass]/[length]**3",
              "type": "string",
              "x-unit-dimensionality": "[current]**2*[time]**3/[mass]/[length]**3"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Electrical conductivity in S/m",
          "title": "Conductivity"
        },
        "resistivity": {
          "anyOf": [
            {
              "description": "pint quantity with dimensionality [mass]*[length]**3/[current]**2/[time]**3",
              "type": "string",
              "x-unit-dimensionality": "[mass]*[length]**3/[current]**2/[time]**3"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Electrical resistivity in \u03a9\u00b7m",
          "title": "Resistivity"
        },
        "permittivity": {
          "anyOf": [
            {
              "description": "pint quantity with dimensionality [current]**2*[time]**4/[mass]/[length]**3",
              "type": "string",
              "x-unit-dimensionality": "[current]**2*[time]**4/[mass]/[length]**3"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Permittivity in F/m",
          "title": "Permittivity"
        },
        "permeability": {
          "anyOf": [
            {
              "description": "pint quantity with dimensionality [mass]*[length]/[current]**2/[time]**2",
              "type": "string",
              "x-unit-dimensionality": "[mass]*[length]/[current]**2/[time]**2"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Permeability in H/m",
          "title": "Permeability"
        }
      },
      "title": "ElectricalProperties",
      "type": "object"
    },
    "EntityTag": {
      "description": "A per-region override matched to a mesh entity by name.\n\nCarries information that is not a material property but still needs to reach\nthe solver for a specific region, as a list of composable, self-describing\n`conditions` (doc 02): a `Magnetization` body force for a magnet block, a\n`FixedTemperature` boundary, etc. Each condition knows its physics, its\nbody/boundary target, and how to emit its own Elmer keywords \u2014 so a region\ncarries only the conditions it actually has, with no flat bag of optional\nscalars.",
      "properties": {
        "tag": {
          "default": "",
          "title": "Tag",
          "type": "string"
        },
        "conditions": {
          "description": "Composable, self-describing conditions (body forces / boundary conditions) this region carries.",
          "items": {
            "discriminator": {
              "mapping": {
                "convection": "#/$defs/Convection",
                "fixed_temperature": "#/$defs/FixedTemperature",
                "heat_flux": "#/$defs/HeatFlux",
                "magnetization": "#/$defs/Magnetization"
              },
              "propertyName": "kind"
            },
            "oneOf": [
              {
                "$ref": "#/$defs/Magnetization"
              },
              {
                "$ref": "#/$defs/FixedTemperature"
              },
              {
                "$ref": "#/$defs/HeatFlux"
              },
              {
                "$ref": "#/$defs/Convection"
              }
            ]
          },
          "title": "Conditions",
          "type": "array"
        }
      },
      "title": "EntityTag",
      "type": "object"
    },
    "FixedTemperature": {
      "description": "Dirichlet temperature boundary condition (thermal, boundary target).",
      "properties": {
        "physics": {
          "$ref": "#/$defs/Physics",
          "default": "thermal"
        },
        "target": {
          "$ref": "#/$defs/ConditionTarget",
          "default": "boundary"
        },
        "kind": {
          "const": "fixed_temperature",
          "default": "fixed_temperature",
          "title": "Kind",
          "type": "string"
        },
        "value": {
          "description": "Fixed temperature (K) imposed on the boundary.",
          "title": "Value",
          "type": "string",
          "x-unit-dimensionality": "[temperature]"
        }
      },
      "required": [
        "value"
      ],
      "title": "FixedTemperature",
      "type": "object"
    },
    "HeatFlux": {
      "description": "Prescribed heat flux boundary condition (thermal, boundary target).",
      "properties": {
        "physics": {
          "$ref": "#/$defs/Physics",
          "default": "thermal"
        },
        "target": {
          "$ref": "#/$defs/ConditionTarget",
          "default": "boundary"
        },
        "kind": {
          "const": "heat_flux",
          "default": "heat_flux",
          "title": "Kind",
          "type": "string"
        },
        "value": {
          "description": "Heat flux (W/m^2) through the boundary.",
          "title": "Value",
          "type": "string",
          "x-unit-dimensionality": "[power]/[length]**2"
        }
      },
      "required": [
        "value"
      ],
      "title": "HeatFlux",
      "type": "object"
    },
    "MagneticProperties": {
      "properties": {
        "rel_permeability": {
          "anyOf": [
            {
              "description": "pint quantity with dimensionality ",
              "type": "string",
              "x-unit-dimensionality": ""
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "\u03bcr: relative permeability (dimensionless)",
          "title": "Rel Permeability"
        },
        "remanence": {
          "anyOf": [
            {
              "description": "pint quantity with dimensionality [mass]/[current]/[time]**2",
              "type": "string",
              "x-unit-dimensionality": "[mass]/[current]/[time]**2"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "B\u1d63: remanence in Tesla (T)",
          "title": "Remanence"
        },
        "coercivity": {
          "anyOf": [
            {
              "description": "pint quantity with dimensionality [current]/[length]",
              "type": "string",
              "x-unit-dimensionality": "[current]/[length]"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Hc: coercivity in A/m",
          "title": "Coercivity"
        }
      },
      "title": "MagneticProperties",
      "type": "object"
    },
    "Magnetization": {
      "description": "Permanent-magnet body force (magnetostatics, body target).\n\nThe *direction* is per-region (in a Halbach array the same N52 block points\nN/E/S/W depending on its slot) and lives here; the *magnitude*\n``|M| = B\u1d63/\u03bc\u2080`` is a material property and is passed into ``to_elmer`` by the\ngenerator. ``direction`` need not be a unit vector \u2014 ``to_elmer`` normalizes\nit (via :meth:`Vec3.normalized`) before scaling, so authoring an\naxis-aligned ``Vec3(0, 1, 0)`` or a raw ``Vec3(0, 2, 0)`` gives the same\nresult.",
      "properties": {
        "physics": {
          "$ref": "#/$defs/Physics",
          "default": "magnetostatics"
        },
        "target": {
          "$ref": "#/$defs/ConditionTarget",
          "default": "body"
        },
        "kind": {
          "const": "magnetization",
          "default": "magnetization",
          "title": "Kind",
          "type": "string"
        },
        "direction": {
          "description": "Magnetization direction (normalized before use); magnitude comes from the material.",
          "properties": {
            "x": {
              "type": "number"
            },
            "y": {
              "type": "number"
            },
            "z": {
              "type": "number"
            }
          },
          "required": [
            "x",
            "y",
            "z"
          ],
          "title": "Direction",
          "type": "object"
        }
      },
      "required": [
        "direction"
      ],
      "title": "Magnetization",
      "type": "object"
    },
    "MaterialProperties": {
      "properties": {
        "name": {
          "default": "",
          "title": "Name",
          "type": "string"
        },
        "tag": {
          "default": "",
          "title": "Tag",
          "type": "string"
        },
        "mechanical": {
          "$ref": "#/$defs/MechanicalProperties"
        },
        "thermal": {
          "$ref": "#/$defs/ThermalProperties"
        },
        "magnetic": {
          "$ref": "#/$defs/MagneticProperties"
        },
        "electrical": {
          "$ref": "#/$defs/ElectricalProperties"
        }
      },
      "title": "MaterialProperties",
      "type": "object"
    },
    "MechanicalProperties": {
      "properties": {
        "density": {
          "anyOf": [
            {
              "description": "pint quantity with dimensionality [mass]/[length]**3",
              "type": "string",
              "x-unit-dimensionality": "[mass]/[length]**3"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "kg/m\u00b3",
          "title": "Density"
        },
        "elastic_modulus": {
          "anyOf": [
            {
              "description": "pint quantity with dimensionality [pressure]",
              "type": "string",
              "x-unit-dimensionality": "[pressure]"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Elastic (Young's) modulus in Pa",
          "title": "Elastic Modulus"
        },
        "yield_strength": {
          "anyOf": [
            {
              "description": "pint quantity with dimensionality [pressure]",
              "type": "string",
              "x-unit-dimensionality": "[pressure]"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Yield strength in Pa",
          "title": "Yield Strength"
        },
        "ultimate_tensile_strength": {
          "anyOf": [
            {
              "description": "pint quantity with dimensionality [pressure]",
              "type": "string",
              "x-unit-dimensionality": "[pressure]"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Ultimate tensile strength in Pa",
          "title": "Ultimate Tensile Strength"
        }
      },
      "title": "MechanicalProperties",
      "type": "object"
    },
    "Physics": {
      "description": "Which physics preset the sif writer wires.\n\nThe string values match the keys of ``PHYSICS_PRESETS`` in ``elmer.sim`` and\nthe historical ``physics=\"magnetostatics\"`` spelling, so existing configs and\nserialized data keep working \u2014 but callers now pass ``Physics.MAGNETOSTATICS``\nand get IDE completion + validation.",
      "enum": [
        "magnetostatics",
        "thermal",
        "electrostatics",
        "linear_elasticity"
      ],
      "title": "Physics",
      "type": "string"
    },
    "ThermalProperties": {
      "properties": {
        "conductivity": {
          "anyOf": [
            {
              "description": "pint quantity with dimensionality [power]/[length]/[temperature]",
              "type": "string",
              "x-unit-dimensionality": "[power]/[length]/[temperature]"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Thermal conductivity in W/(m\u00b7K)",
          "title": "Conductivity"
        },
        "specific_heat_capacity": {
          "anyOf": [
            {
              "description": "pint quantity with dimensionality [energy]/[mass]/[temperature]",
              "type": "string",
              "x-unit-dimensionality": "[energy]/[mass]/[temperature]"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Specific heat capacity in J/(kg\u00b7K)",
          "title": "Specific Heat Capacity"
        },
        "convective_heat_transfer_coefficient": {
          "anyOf": [
            {
              "description": "pint quantity with dimensionality [power]/[length]**2/[temperature]",
              "type": "string",
              "x-unit-dimensionality": "[power]/[length]**2/[temperature]"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Convective heat transfer coefficient in W/(m\u00b2\u00b7K)",
          "title": "Convective Heat Transfer Coefficient"
        },
        "glass_transition_temperature": {
          "anyOf": [
            {
              "description": "pint quantity with dimensionality [temperature]",
              "type": "string",
              "x-unit-dimensionality": "[temperature]"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Glass transition temperature in K",
          "title": "Glass Transition Temperature"
        }
      },
      "title": "ThermalProperties",
      "type": "object"
    }
  },
  "description": "The single config that drives both the mesher and the sif writer.",
  "properties": {
    "materials": {
      "items": {
        "$ref": "#/$defs/MaterialProperties"
      },
      "title": "Materials",
      "type": "array"
    },
    "tags": {
      "items": {
        "$ref": "#/$defs/EntityTag"
      },
      "title": "Tags",
      "type": "array"
    },
    "STEP": {
      "default": "data/geometry.step",
      "title": "Step",
      "type": "string"
    },
    "global_mesh_size": {
      "default": 1.0,
      "description": "Global mesh size in meters",
      "title": "Global Mesh Size",
      "type": "number"
    }
  },
  "title": "MeshingConfig",
  "type": "object"
}
